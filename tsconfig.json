{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "types": [
      "node",
      "@cucumber/cucumber"
    ]
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "features/**/*.ts",
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}