# Environment variables for Playwright Cucumber TypeScript project
BASE_URL=https://sauce-demo.myshopify.com/
HEADLESS=false
BROWSER=chromium
TIMEOUT=30000
ALLURE_ENABLED=true

# BrowserStack integration settings
BROWSERSTACK_ENABLED=false
BROWSERSTACK_USERNAME=xxxxxxxx
BROWSERSTACK_ACCESS_KEY=xxxxxxxx

# Xray integration settings
XRAY_ENABLED=false
JIRA_PROJECT=DEMO
JIRA_URL=https://your-jira-instance.atlassian.net
XRAY_CLIENT_SECRET=your-xray-client-secret
XRAY_CLIENT_ID=your-xray-client-id

# Payment information for checkout tests (store to more secure location in production)
CARD_NUMBER=4242424242424242
NAME_ON_CARD=John Doe
EXPIRATION_DATE=12/34
SECURITY_CODE=123